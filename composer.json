{
    "name": "hydrakit/database",
    "description": "Database library for Hydra PHP framework",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Hydra\\Database\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hydra\\Database\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "William Hleucka",
            "email": "william.hleucka@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "ext-pdo_sqlite": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "0.2.x-dev"
        }
    }
}
